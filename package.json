{
  "name": "rpg-world",
  "version": "0.1.0",
  "author": "Rebeca Morais Cruz (Rebs Tech Studio)",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "private": true,
  "scripts": {
    "infra": "npx tsx scripts/infra.ts",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "db:ui": "open http://localhost:54323 && open http://localhost:54324",
    "clean": "npm run infra clean",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run --config ./test/vitest.config.unit.ts",
    "test:integration": "vitest run --config ./test/vitest.config.integration.ts",
    "test:ui": "vitest --ui",
    "lint": "eslint",
    "format": "prettier --write .",
    "prepare": "husky",
    "postinstall": "husky install && npx tsx ./scripts/post-install-cleanup.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "@tanstack/react-query": "^5.90.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.0.18",
    "chalk": "^5.6.2",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sade": "^1.8.1",
    "server-only": "^0.0.1",
    "supabase": "^2.76.16",
    "tailwindcss": "^4",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
