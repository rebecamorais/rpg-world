{
  "name": "rpg-world",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "private": true,
  "scripts": {
    "dev": "npm run db:dev:start && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "prepare": "husky",
    "postinstall": "husky install && npx tsx ./scripts/post-install-cleanup.ts",
    "setup": "npx tsx ./scripts/setup-symlinks.ts",
    "db:dev:start": "supabase start --workdir database/db-dev && npm run types:update",
    "db:dev:stop": "supabase stop --workdir database/db-dev",
    "db:dev:status": "supabase status --workdir database/db-dev",
    "db:dev:ui": "open http://localhost:54323 && open http://localhost:54324",
    "db:test:start": "supabase start --workdir database/db-test",
    "db:test:stop": "supabase stop --workdir database/db-test",
    "db:test:reset": "supabase db reset --workdir database/db-test",
    "db:test:status": "supabase status --workdir database/db-test",
    "types:update": "supabase gen types typescript --local --workdir database/db-dev > lib/types/database.ts",
    "infra:clean": "docker stop $(docker ps -aq) 2>/dev/null || true && docker system prune --volumes -f",
    "infra:init": "npm run setup && npm run infra:clean && npm run infra:start",
    "infra:start": "npm run db:dev:start && npm run db:test:start",
    "infra:stop": "npm run db:dev:stop && npm run db:test:stop",
    "test": "npm run test:unit && npm run infra:start && npm run test:integration",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:unit": "vitest run --config ./test/vitest.config.unit.ts",
    "test:integration": "vitest run --config ./test/vitest.config.integration.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "@tanstack/react-query": "^5.90.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.0.18",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "server-only": "^0.0.1",
    "supabase": "^2.76.16",
    "tailwindcss": "^4",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
