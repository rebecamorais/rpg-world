# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
.vscode/

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Supabase CLI runtime (gerado automaticamente)
# Pasta supabase e config.toml precis ser comitada sempre
**/supabase/.branches/
**/supabase/.temp/
**/.branches/
**/.temp/
# Ignorar links simbólicos criados pelo script
**/supabase/migrations
**/supabase/seeds
**/supabase/snippets
